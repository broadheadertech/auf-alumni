# Convex — set automatically by `npx convex dev`
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# Email (Resend) — used in later stories
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=hello@aufalumni.example.com

# Sentry — used in later stories
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# PostHog — used in later stories
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Registry — stub mode in v1; live mode requires AUF partnership
REGISTRY_MODE=stub
AUF_REGISTRY_ENDPOINT=
AUF_REGISTRY_API_KEY=
AUF_EMAIL_DOMAINS=auf.edu.ph,students.auf.edu.ph

# Payment processor — Phase 3
PAYMENT_PROCESSOR_SECRET_KEY=
PAYMENT_PROCESSOR_WEBHOOK_SECRET=

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_NOTIFICATION_EMAIL=ops@aufalumni.example.com
